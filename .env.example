# ---- cyberwatch database ----
PGHOST=15.207.97.16
PGPORT=5432
PGDATABASE=cyberwatch
PGUSER=vapt_service
PGPASSWORD=change_me
PGSSL=false

# ---- service ----
PORT=8080
DEFAULT_TENANT=00000000-0000-0000-0000-000000000001
LOG_LEVEL=info

# ---- SAFETY: active scanning kill-switch ----
# Active/intrusive PT is DISABLED unless this is explicitly "true".
# Even when true, a valid, in-scope authorization record is still required per target.
ACTIVE_SCANS_ENABLED=false

# Optional external tool paths (auto-detected on PATH if omitted)
ZAP_BASELINE=zap-baseline.py
NUCLEI_BIN=nuclei
NMAP_BIN=nmap
TESTSSL_BIN=testssl.sh

# ---- auth ----
JWT_SECRET=please_generate_a_long_random_string
JWT_EXPIRY=12h
